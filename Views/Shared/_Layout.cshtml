@using System.Security.Claims
@inject TinyPOSApp.Data.TinyPOSContext dbContext
@{
    string userImageUrl = null;
    if (User.Identity?.IsAuthenticated == true)
    {
        var userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (Guid.TryParse(userIdStr, out var uId))
        {
            var p = dbContext.Profiles.Find(uId);
            userImageUrl = p?.ImageUrl;
        }
    }
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TinyPOS</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'IBM Plex Sans', sans-serif; }
        .font-mono { font-family: 'IBM Plex Mono', monospace; }
        .font-label { font-family: 'Space Grotesk', sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        /* Custom scrollbar for industrial feel */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #697d8f; }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "surface-variant": "#d0e5fa",
                        "tertiary": "#c00815",
                        "on-background": "#203444",
                        "surface-container-high": "#d9eafc",
                        "error": "#9f403d",
                        "background": "#f6f9ff",
                        "error-container": "#fe8983",
                        "outline-variant": "#a0b4c8",
                        "surface": "#f6f9ff",
                        "outline": "#697d8f",
                        "on-primary": "#f7f7ff",
                        "primary-container": "#dae2fd",
                        "surface-container-lowest": "#ffffff",
                        "primary-fixed": "#dae2fd",
                        "surface-container": "#e2effe",
                        "on-surface-variant": "#4d6172",
                        "on-surface": "#203444",
                        "secondary": "#006d4b",
                        "primary": "#565e74"
                    },
                    borderRadius: { "DEFAULT": "0px", "lg": "0px", "xl": "0px", "full": "0px" }
                }
            }
        }
    </script>
</head>
<body class="bg-background text-on-surface overflow-hidden">
    <!-- TopNavBar -->
    <header class="bg-slate-900 dark:bg-black fixed top-0 w-full border-0 flex justify-between items-center px-4 h-12 z-50">
        <!-- Left: Screen Name -->
        <div class="flex items-center px-4 w-1/3">
            <span class="font-sans font-bold uppercase tracking-widest text-xs text-slate-300">@ViewData["Title"]</span>
        </div>
        <!-- Center: Brand Name -->
        <div class="flex items-center justify-center w-1/3">
            <span class="font-mono font-bold text-white text-lg tracking-tighter">TinyPOS</span>
        </div>
        <!-- Right: Current Time & Logout -->
        <div class="flex items-center justify-end px-4 w-1/3 gap-4">
            <span class="font-mono text-xs text-slate-400 uppercase" id="clock">00:00:00</span>
            <form asp-controller="Account" asp-action="Logout" method="post" class="flex m-0">
                <button type="submit" class="font-mono text-xs text-sky-400 hover:text-sky-300 font-bold tracking-widest uppercase transition-colors">LOGOUT</button>
            </form>
        </div>
    </header>

    <!-- SideNavBar -->
    <aside class="bg-slate-50 fixed left-0 top-12 h-[calc(100vh-48px)] w-20 border-r border-slate-200 flex flex-col items-center py-4 z-40 transition-colors duration-75">
        <a href="/Account/Profile" class="flex flex-col items-center gap-1 mb-8 hover:opacity-80 transition-opacity cursor-pointer text-decoration-none">
            <div class="w-10 h-10 bg-slate-200 flex items-center justify-center border border-slate-300 overflow-hidden">
                @if (!string.IsNullOrEmpty(userImageUrl))
                {
                    <img src="@userImageUrl" alt="Profile" class="w-full h-full object-cover" />
                }
                else
                {
                    <span class="material-symbols-outlined text-slate-600">person</span>
                }
            </div>
            <div class="text-center">
                <span class="font-['IBM_Plex_Sans'] font-bold uppercase tracking-wider text-[9px] text-slate-900 block">@User.Identity?.Name</span>
                <span class="font-['IBM_Plex_Sans'] uppercase tracking-wider text-[7px] text-slate-500">Station 01</span>
            </div>
        </a>
        <nav class="flex flex-col w-full gap-1 px-1">
            <a href="/" class="flex flex-col items-center py-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "bg-blue-100 text-slate-900 border-l-4 border-slate-900" : "text-slate-500 hover:bg-slate-200") font-['IBM_Plex_Sans'] font-bold uppercase tracking-wider text-[10px] transition-colors duration-75 no-underline">
                <span class="material-symbols-outlined mb-1">point_of_sale</span>
                Terminal
            </a>
            <a href="/Products" class="flex flex-col items-center py-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "bg-blue-100 text-slate-900 border-l-4 border-slate-900" : "text-slate-500 hover:bg-slate-200") font-['IBM_Plex_Sans'] font-bold uppercase tracking-wider text-[10px] transition-colors duration-75 no-underline">
                <span class="material-symbols-outlined mb-1">inventory_2</span>
                Products
            </a>
            <a href="/Transactions" class="flex flex-col items-center py-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Transactions" ? "bg-blue-100 text-slate-900 border-l-4 border-slate-900" : "text-slate-500 hover:bg-slate-200") font-['IBM_Plex_Sans'] font-bold uppercase tracking-wider text-[10px] transition-colors duration-75 no-underline">
                <span class="material-symbols-outlined mb-1">receipt_long</span>
                Logs
            </a>
        </nav>
    </aside>

    <main class="ml-20 mt-12 h-[calc(100vh-48px)]">
        @RenderBody()
    </main>

    <script>
        function updateTime() {
            const now = new Date();
            document.getElementById('clock').textContent = now.toLocaleTimeString('en-GB', { hour12: false });
        }
        setInterval(updateTime, 1000);
        updateTime();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
