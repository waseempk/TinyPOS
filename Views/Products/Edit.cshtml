@model TinyPOSApp.Models.Product

@{
    ViewData["Title"] = "Product Editor";
    bool isNew = string.IsNullOrEmpty(Model.Name);
}

<div class="h-full flex flex-col p-6 lg:p-8 overflow-y-auto">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="text-error font-mono text-xs mb-4"></div>

        <!-- Header Section -->
        <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-4 border-b border-outline-variant pb-6">
            <div>
                <h1 class="font-label text-3xl font-bold text-on-background tracking-tight">
                    @(isNew ? "NEW_SKU_ENTRY" : Model.Sku)
                </h1>
            </div>
            <div class="flex gap-2">
                <a href="/Products" class="px-6 py-2 border border-outline font-label text-sm hover:bg-surface-container transition-colors no-underline text-slate-800">CANCEL_ACTION</a>
                <button type="submit" class="px-6 py-2 bg-slate-900 text-white font-label text-sm hover:bg-primary duration-75">COMMIT_CHANGES</button>
            </div>
        </div>

        <div class="grid grid-cols-12 gap-6 pb-12">
            <!-- Left Column: Basic Info -->
            <div class="col-span-12 lg:col-span-8 space-y-6">
                <!-- Basic Info Panel -->
                <section class="bg-white border border-slate-200 p-6">
                    <div class="flex items-center gap-2 mb-6 border-l-4 border-slate-900 pl-3">
                        <span class="material-symbols-outlined text-slate-900">info</span>
                        <h2 class="font-label font-bold text-lg uppercase tracking-tight">Basic Information</h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1">
                            <label class="block font-mono text-[10px] text-slate-500 uppercase">Product Name</label>
                            <input asp-for="Name" class="w-full border border-slate-300 p-3 font-mono text-sm focus:border-emerald-600 focus:ring-0 outline-none uppercase" placeholder="ENTER PRODUCT LABEL" type="text" required />
                        </div>
                        <div class="space-y-1">
                            <label class="block font-mono text-[10px] text-slate-500 uppercase">Internal SKU</label>
                            <input asp-for="Sku" class="w-full border border-slate-300 bg-slate-50 p-3 font-mono text-sm focus:border-emerald-600 focus:ring-0 outline-none uppercase" type="text" required />
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="block font-mono text-[10px] text-slate-500 uppercase">Description</label>
                            <textarea asp-for="Description" class="w-full border border-slate-300 p-3 font-sans text-sm focus:border-emerald-600 focus:ring-0 outline-none" placeholder="Technical specifications and handling instructions..." rows="3"></textarea>
                        </div>
                    </div>
                </section>
            </div>

            <!-- Right Column: Commercials & Media -->
            <div class="col-span-12 lg:col-span-4 space-y-6">
                <!-- Commercials Panel -->
                <section class="bg-white border border-slate-200 p-6">
                    <div class="flex items-center gap-2 mb-6 border-l-4 border-emerald-600 pl-3">
                        <span class="material-symbols-outlined text-emerald-600">payments</span>
                        <h2 class="font-label font-bold text-lg uppercase tracking-tight">Commercials</h2>
                    </div>
                    <div class="space-y-4">
                        <div class="grid grid-cols-2 gap-4">
                            <div class="space-y-1">
                                <label class="block font-mono text-[10px] text-slate-500 uppercase">Cost Price</label>
                                <div class="relative">
                                    <span class="absolute left-3 top-1/2 -translate-y-1/2 font-mono text-slate-400">$</span>
                                    <input asp-for="CostPrice" type="number" step="0.01" class="w-full border border-slate-300 p-3 pl-8 font-mono text-sm focus:border-slate-900 outline-none" />
                                </div>
                            </div>
                            <div class="space-y-1">
                                <label class="block font-mono text-[10px] text-slate-500 uppercase">Sale Price</label>
                                <div class="relative">
                                    <span class="absolute left-3 top-1/2 -translate-y-1/2 font-mono text-slate-400">$</span>
                                    <input asp-for="SalePrice" type="number" step="0.01" class="w-full border border-slate-300 p-3 pl-8 font-mono text-sm focus:border-emerald-600 outline-none font-bold" required />
                                </div>
                            </div>
                            <div class="space-y-1">
                                <label class="block font-mono text-[10px] text-slate-500 uppercase">Tax (%)</label>
                                <div class="relative">
                                    <input asp-for="TaxPercent" type="number" step="0.01" class="w-full border border-slate-300 p-3 font-mono text-sm focus:border-slate-900 outline-none" />
                                </div>
                            </div>
                            <div class="space-y-1">
                                <label class="block font-mono text-[10px] text-slate-500 uppercase">Discount (%)</label>
                                <div class="relative">
                                    <input asp-for="DiscountPercent" type="number" step="0.01" class="w-full border border-slate-300 p-3 font-mono text-sm focus:border-slate-900 outline-none" />
                                </div>
                            </div>
                        </div>

                        <div class="bg-slate-900 text-white p-4">
                            <div class="flex justify-between items-center mb-1">
                                <span class="font-mono text-[10px] uppercase text-slate-400">Status Check</span>
                                <span class="font-mono text-[10px] bg-emerald-600 px-1 text-black font-bold">READY</span>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-slate-100">
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input name="ApplyBulkDiscount" value="true" @(Model.ApplyBulkDiscount == true ? "checked" : "") type="checkbox" class="w-4 h-4 rounded-none border-slate-300 text-slate-900 focus:ring-0" />
                                <span class="font-mono text-[10px] uppercase text-slate-600 group-hover:text-slate-900 transition-colors">Apply bulk discount logic</span>
                            </label>
                        </div>
                    </div>
                </section>

                <!-- Media/Assets Panel -->
                <section class="bg-white border border-slate-200 p-6">
                    <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-2 mb-6 border-l-4 border-slate-900 pl-3">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-slate-900">image</span>
                            <h2 class="font-label font-bold text-lg uppercase tracking-tight">Product Media</h2>
                        </div>
                        <button type="button" id="btnRemoveImage" class="text-xs text-error hover:text-error-dim font-bold uppercase flex items-center gap-1 transition-colors">
                            <span class="material-symbols-outlined text-sm">delete</span> Remove
                        </button>
                    </div>
                    
                    <input type="hidden" name="removeImage" id="removeImageFlag" value="false" />

                    <div class="grid grid-cols-2 gap-2 mb-4">
                        <div class="aspect-square bg-slate-100 border border-slate-200 flex items-center justify-center overflow-hidden">
                            <img id="imagePreview" src="@Model.ImageUrl" class="object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-300 @(string.IsNullOrEmpty(Model.ImageUrl) ? "hidden" : "")" />
                            <span id="imagePlaceholder" class="material-symbols-outlined text-slate-300 text-4xl @(!string.IsNullOrEmpty(Model.ImageUrl) ? "hidden" : "")">inventory_2</span>
                        </div>
                        <label class="aspect-square bg-slate-50 border border-dashed border-slate-300 flex flex-col items-center justify-center text-slate-400 hover:text-slate-600 hover:bg-slate-100 cursor-pointer transition-all relative">
                            <input type="file" name="uploadImage" id="uploadImageInput" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" accept="image/*" />
                            <span class="material-symbols-outlined">add_a_photo</span>
                            <span class="font-mono text-[8px] mt-1">UPLOAD_IMG</span>
                        </label>
                    </div>
                    <p class="font-mono text-[10px] text-slate-400 text-center uppercase">Supported: JPG, PNG, WEBP</p>
                </section>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.getElementById('uploadImageInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.getElementById('imagePreview');
                    img.src = e.target.result;
                    img.classList.remove('hidden');
                    document.getElementById('imagePlaceholder').classList.add('hidden');
                    document.getElementById('removeImageFlag').value = 'false';
                }
                reader.readAsDataURL(file);
            }
        });

        document.getElementById('btnRemoveImage').addEventListener('click', function(e) {
            document.getElementById('uploadImageInput').value = ''; // clear file input
            document.getElementById('imagePreview').src = '';
            document.getElementById('imagePreview').classList.add('hidden');
            document.getElementById('imagePlaceholder').classList.remove('hidden');
            document.getElementById('removeImageFlag').value = 'true';
        });
    </script>
}
