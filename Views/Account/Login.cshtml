@model TinyPOSApp.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>TINYPOS | AUTHENTICATION_REQUIRED</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;700&family=Inter:wght@400;700&family=Space+Grotesk:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-surface-variant": "#4d6172",
                        "primary": "#0F172A",
                        "surface-tint": "#565e74",
                        "primary-fixed-dim": "#ccd4ee",
                        "on-secondary-fixed-variant": "#006948",
                        "surface-bright": "#f6f9ff",
                        "on-primary-fixed-variant": "#535b71",
                        "error-container": "#fe8983",
                        "surface": "#F8FAFC",
                        "tertiary-dim": "#ab000f",
                        "surface-container": "#e2effe",
                        "secondary-container": "#85f8c4",
                        "tertiary": "#c00815",
                        "primary-dim": "#4a5268",
                        "on-primary": "#ffffff",
                        "background": "#E2E8F0",
                        "on-tertiary": "#fff7f6",
                        "inverse-surface": "#080f14",
                        "secondary": "#006d4b",
                        "on-secondary-fixed": "#004931",
                        "on-background": "#203444",
                        "on-secondary-container": "#005e40",
                        "primary-container": "#dae2fd",
                        "error-dim": "#4e0309",
                        "tertiary-fixed-dim": "#e72f2d",
                        "outline": "#697d8f",
                        "inverse-primary": "#dae2fd",
                        "primary-fixed": "#dae2fd",
                        "secondary-fixed": "#85f8c4",
                        "error": "#9f403d",
                        "surface-container-lowest": "#ffffff",
                        "outline-variant": "#CBD5E1",
                        "on-secondary": "#e6ffef",
                        "on-error": "#fff7f6",
                        "on-error-container": "#752121",
                        "surface-container-high": "#d9eafc",
                        "secondary-fixed-dim": "#76eab6",
                        "surface-dim": "#c4ddf5",
                        "on-tertiary-fixed": "#000000",
                        "surface-container-low": "#ecf4ff",
                        "secondary-dim": "#005f41",
                        "tertiary-container": "#fa3d38",
                        "surface-container-highest": "#d0e5fa",
                        "surface-variant": "#d0e5fa",
                        "inverse-on-surface": "#979ea5",
                        "on-surface": "#203444",
                        "on-primary-fixed": "#373f54",
                        "on-primary-container": "#4a5167",
                        "on-tertiary-fixed-variant": "#220001",
                        "on-tertiary-container": "#000000",
                        "tertiary-fixed": "#fa3d38"
                    },
                    "borderRadius": {
                        "DEFAULT": "0px",
                        "lg": "0px",
                        "xl": "0px",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["IBM Plex Sans", "sans-serif"],
                        "body": ["IBM Plex Sans", "sans-serif"],
                        "label": ["Space Grotesk", "sans-serif"],
                        "mono": ["IBM Plex Mono", "monospace"]
                    }
                },
            },
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        body {
            font-family: 'IBM Plex Sans', sans-serif;
            background-color: #E2E8F0;
        }
        .mono {
            font-family: 'IBM Plex Mono', monospace;
        }
        input:focus {
            outline: none !important;
            border-color: #059669 !important;
            box-shadow: none !important;
        }
        * {
            border-radius: 0px !important;
        }
    </style>
</head>
<body class="flex flex-col min-h-screen items-center justify-center p-4">
    <main class="w-full max-w-[420px] flex flex-col gap-6">
        <header class="text-center">
            <h1 class="text-4xl font-headline font-bold tracking-tighter text-primary">TINYPOS</h1>
            <p class="text-[10px] tracking-[0.2em] font-mono text-on-surface-variant mt-2 uppercase"></p>
        </header>

        <section class="bg-surface border border-outline-variant p-8 flex flex-col gap-8">
            <div class="flex items-center justify-between border-b border-outline-variant pb-4">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-xl" data-icon="lock">lock</span>
                    <h2 class="font-mono text-sm font-semibold text-primary">Sign In</h2>
                </div>
            </div>

            <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post" class="flex flex-col gap-6">
                <!-- Operative ID Field -->
                <div class="flex flex-col gap-1.5">
                    <label class="font-mono text-[10px] font-bold text-on-surface uppercase tracking-tight" for="operative_id">OPERATIVE ID / EMAIL</label>
                    <div class="relative">
                        <input asp-for="Email" id="operative_id" class="w-full bg-surface-container-low border border-outline-variant px-3 py-2.5 font-mono text-sm text-primary placeholder:text-outline-variant focus:border-secondary transition-colors" placeholder="admin@tinypos.com" autocomplete="username" />
                    </div>
                </div>

                <!-- Security PIN Field -->
                <div class="flex flex-col gap-1.5">
                    <label class="font-mono text-[10px] font-bold text-on-surface uppercase tracking-tight" for="security_pin">SECURITY PIN</label>
                    <div class="relative">
                        <input asp-for="Pin" type="password" id="security_pin" class="w-full bg-surface-container-low border border-outline-variant px-3 py-2.5 font-mono text-sm text-primary placeholder:text-outline-variant focus:border-secondary transition-colors" placeholder="••••" autocomplete="current-password" />
                    </div>
                </div>

                <!-- Authenticate Button -->
                <button type="submit" class="bg-primary text-on-primary py-3 px-6 flex items-center justify-center gap-3 hover:bg-slate-800 active:scale-[0.98] transition-all duration-75 group border border-primary">
                    <span class="font-headline font-bold text-sm tracking-widest uppercase">AUTHENTICATE</span>
                    <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform" data-icon="login">login</span>
                </button>
            </form>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 p-3 border-l-4 border-red-600">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        foreach (var error in modelState.Errors)
                        {
                            <p class="font-mono text-[10px] leading-relaxed text-red-600 font-bold uppercase">
                                ACCESS DENIED: @error.ErrorMessage
                            </p>
                        }
                    }
                </div>
            }
            else
            {
                <div class="bg-surface-container p-3 border-l-4 border-primary">
                    <p class="font-mono text-[10px] leading-relaxed text-on-surface-variant">
                        WARNING: UNAUTHORIZED ACCESS ATTEMPTS ARE LOGGED. ALL TERMINAL ACTIVITY IS MONITORED BY NETWORK_ADMIN.
                    </p>
                </div>
            }
        </section>
    </main>

    <!-- Decorative Grid Background Elements -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
        <div class="absolute top-0 right-0 w-64 h-64 border-r border-t border-slate-300 translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 border-l border-b border-slate-300 -translate-x-1/2 translate-y-1/2"></div>
        <div class="absolute inset-0 bg-[radial-gradient(#CBD5E1_1px,transparent_1px)] [background-size:24px_24px] opacity-20"></div>
    </div>
</body>
</html>
